	<key>PayloadDescription</key>
	<string>Grants the Wired Server daemon Full Disk Access so it can serve files from external volumes. Required because macOS blocks LaunchDaemon processes from accessing removable APFS volumes via TCC.</string>
	<key>PayloadDisplayName</key>
	<string>Wired Server - Privacy Policy</string>
