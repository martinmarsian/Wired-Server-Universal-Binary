	<key>PayloadContent</key>
	<array>
		<dict>
			<key>PayloadDescription</key>
			<string>Full Disk Access for Wired Server daemon</string>
			<key>PayloadIdentifier</key>
			<string>fr.read-write.WiredServer.tcc.policy</string>
			<key>PayloadOrganization</key>
			<string>Wired Server</string>
